SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
POSTGRESQL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
OPENAI_API_KEY=your_openai_api_key_here
SERP_API_KEY=your_serp_api_key_here

# Optional runtime controls
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REASONING_MODEL=gpt-4o-mini
OPENAI_STRATEGY_MODEL=gpt-4o-mini
FIRECRAWL_API_KEY=
CONTENTOG_DISABLE_DB_FALLBACK=true
CONTENTOG_KEYWORD_LIMIT=3
